; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="voidborne"
run/main_scene="uid://uno1klrruv6"
config/features=PackedStringArray("4.4", "GL Compatibility")
config/icon="res://sprites/icon.svg"

[autoload]

Global="*res://scripts/core/global.gd"
Dialogic="*res://addons/dialogic/Core/DialogicGameHandler.gd"

[dialogic]

directories/dch_directory={
"???": "res://dialogic/timelines/void_nexus/???.dch",
"lethos": "res://dialogic/characters/outlands/lethos.dch",
"nym": "res://dialogic/characters/outlands/nym.dch",
"nyra": "res://dialogic/characters/outlands/nyra.dch",
"orren": "res://dialogic/characters/outlands/orren.dch",
"ryn": "res://dialogic/characters/outlands/ryn.dch",
"sile": "res://dialogic/characters/outlands/sile.dch",
"valen": "res://dialogic/characters/outlands/valen.dch",
"venn": "res://dialogic/characters/outlands/venn.dch"
}
directories/dtl_directory={
"end": "res://dialogic/timelines/void_nexus/end.dtl",
"forsaken_prism_intro": "res://dialogic/timelines/outlands/forsaken_prism_intro.dtl",
"lethos_end": "res://dialogic/timelines/outlands/lethos_end.dtl",
"lethos_start": "res://dialogic/timelines/outlands/lethos_start.dtl",
"mykl": "res://dialogic/timelines/outlands/nyra.dtl",
"nym": "res://dialogic/timelines/outlands/nym.dtl",
"orren_underground": "res://dialogic/timelines/outlands/orren_underground.dtl",
"ryn_closed": "res://dialogic/timelines/outlands/ryn_closed.dtl",
"sile": "res://dialogic/timelines/outlands/sile.dtl",
"tutorial": "res://dialogic/timelines/void_nexus/tutorial.dtl",
"valen": "res://dialogic/timelines/outlands/valen.dtl",
"venn": "res://dialogic/timelines/outlands/venn.dtl"
}
layout/style_directory={
"": "res://dialogic/main.tres",
"main": "res://dialogic/main.tres"
}
layout/style_list=["res://dialogic/main.tres"]
layout/default_style="res://dialogic/main.tres"
extensions_folder="res://addons/dialogic_additions"
text/letter_speed=0.01
text/initial_text_reveal_skippable=true
text/text_reveal_skip_delay=0.1
text/advance_delay=0.1
text/autoadvance_per_character_delay=0.1
text/autoadvance_ignored_characters_enabled=true
animations/join_default_length=0.5
animations/join_default_wait=true
animations/leave_default_length=0.5
animations/leave_default_wait=true
animations/cross_fade_default_length=0.5
choices/autofocus_first=true
choices/delay=0.2
choices/reveal_delay=0
choices/reveal_by_input=false
save/autosave_delay=60.0
save/encryption_on_exports_only=true
text/autopauses={}
audio/channel_defaults={
"": {
"audio_bus": "",
"fade_length": 0.0,
"loop": false,
"volume": 0.0
},
"music": {
"audio_bus": "",
"fade_length": 0.0,
"loop": true,
"volume": 0.0
}
}

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg", "res://addons/godot_super-wakatime/plugin.cfg")

[global_group]

player=""
enemy=""
hittable=""

[gui]

theme/custom_font="uid://b0p4jmx2wjx20"

